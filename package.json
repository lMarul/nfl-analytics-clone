{
  "name": "nfl-analytics-clone",
  "version": "1.0.0",
  "description": "NFL Analytics with Application Insights",
  "type": "module",
  "scripts": {
    "build": "esbuild appInsights.js --bundle --outfile=dist/appInsights.bundle.js --format=iife --global-name=AppInsightsInit",
    "dev": "esbuild appInsights.js --bundle --outfile=dist/appInsights.bundle.js --format=iife --global-name=AppInsightsInit --watch"
  },
  "dependencies": {
    "@microsoft/applicationinsights-web": "^3.3.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
